# Example secrets file - copy to secrets.yaml and encrypt with sops
# DO NOT commit the unencrypted secrets.yaml file!

github_token: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
gitlab_token: glpat-xxxxxxxxxxxxxxxxxxxx

# OpenWeather API key (the "APPID" query param) for the waybar weather widget
weather_appid: 0123456789abcdef0123456789abcdef

# One entry per user in local.nix, named "<username>_password".
# Value is a password hash from: mkpasswd -m yescrypt
lanath_password: $y$j9T$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
mushu_password: $y$j9T$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
